---
import type { GetStaticPaths } from "astro";

import Layout from "../../../layouts/Layout.astro";
import {
  getAllBoards,
  getBoardBySlug,
  getExampleMarkdownBody,
  getExampleMeta,
  slugifyUrlSegment,
  socSlugFromCpu,
} from "../../../lib/data";
import { renderMarkdownToHtml } from "../../../lib/renderMarkdown";
import { STATUS_LABEL_ZH } from "../../../lib/status-labels";

export const getStaticPaths: GetStaticPaths = () => {
  const paths: { params: { board: string; example: string } }[] = [];
  for (const b of getAllBoards()) {
    for (const e of b.examples) {
      paths.push({ params: { board: b.slug, example: e.slug } });
    }
  }
  return paths;
};

const boardSlug = Astro.params.board!;
const exampleSlug = Astro.params.example!;

const board = getBoardBySlug(boardSlug);
const ex = getExampleMeta(boardSlug, exampleSlug);
const md = ex ? getExampleMarkdownBody(boardSlug, exampleSlug) : undefined;

if (!board || !ex || !md) {
  return Astro.redirect(board ? `/boards/${encodeURIComponent(board.slug)}/` : "/");
}

const contentHtml = await renderMarkdownToHtml(md);

const sv = board.socVendor ?? "Unknown";
const svSlug = slugifyUrlSegment(sv);
const socSlug = socSlugFromCpu(board.cpu);
const rawDocPath = ex.mdGlobKey
  .replace(/\\/g, "/")
  .replace(/^\.\.\/\.\.\//, "")
  .replace(/^board-docs\/boards\//, "board-docs/");
const sourceDocUrl = `/${rawDocPath}`;
---

<Layout title={`${ex.title} — ${board.product}`}>
  <div class="py-8">

    <!-- Header + meta -->
    <header class="mb-6 flex items-start justify-between gap-4">
      <div>
        <p class="text-muted-foreground mb-1 text-sm">{board.product}</p>
        <h1 class="text-foreground text-2xl font-semibold tracking-tight sm:text-3xl">{ex.title}</h1>
        <div class="mt-3 flex flex-wrap items-center gap-2 text-sm">
          <span class="bg-secondary text-secondary-foreground rounded-md px-2 py-0.5 text-xs">
            {STATUS_LABEL_ZH[ex.status]}
          </span>
          {ex.sys ? <span class="text-muted-foreground">系统：{ex.sys}</span> : null}
          {ex.lastUpdate ? <span class="text-muted-foreground">更新：{ex.lastUpdate}</span> : null}
        </div>
      </div>
      <button
        id="use-in-vscode-button"
        type="button"
        class="bg-primary text-primary-foreground hover:bg-primary/90 hidden shrink-0 rounded-md px-3 py-1.5 text-sm transition-colors"
        data-model={board.product}
        data-profile={ex.title}
        data-source-doc-url={sourceDocUrl}
      >
        在 VS Code 中使用
      </button>
    </header>

    <!-- Divider -->
    <hr class="border-border mb-8" />

    <!-- Markdown body -->
    <article class="prose prose-slate dark:prose-invert max-w-none prose-img:rounded-lg prose-img:shadow-sm prose-pre:rounded-lg" set:html={contentHtml} />
  </div>
</Layout>

<script>
  const button = document.getElementById("use-in-vscode-button");
  if (button instanceof HTMLButtonElement) {
    const isVSCodeWebView = navigator.userAgent.includes("Code/");
    if (isVSCodeWebView) {
      button.classList.remove("hidden");
      button.addEventListener("click", () => {
        const model = button.dataset.model ?? "";
        const profile = button.dataset.profile ?? "";
        const sourceDocUrl = button.dataset.sourceDocUrl ?? "";
        const url = sourceDocUrl ? new URL(sourceDocUrl, window.location.origin).href : window.location.href;

        window.parent.postMessage({
          type: "copilot",
          url,
          model,
          profile,
        }, '*');
      });
    }
  }
</script>
