---
import type { GetStaticPaths } from "astro";

import Layout from "../../layouts/Layout.astro";
import { getAllBoards, getBoardBySlug, getBoardReadmeBody } from "../../lib/data";
import { renderMarkdownToHtml } from "../../lib/renderMarkdown";
import { STATUS_LABEL_ZH } from "../../lib/status-labels";

export const getStaticPaths: GetStaticPaths = () =>
  getAllBoards().map((b) => ({ params: { board: b.slug } }));

const boardSlug = Astro.params.board!;
const board = getBoardBySlug(boardSlug);

if (!board) {
  return Astro.redirect("/");
}

const introMd = getBoardReadmeBody(board.slug, "zh") ?? "";
const introHtml = introMd ? await renderMarkdownToHtml(introMd) : "";
---

<Layout title={`${board.product} — RuyiSDK Examples`}>
  <div class="mx-auto max-w-4xl px-4 py-8 sm:px-6">
    <nav class="text-muted-foreground mb-6 text-sm">
      <a href="/" class="hover:text-foreground underline-offset-4 hover:underline">首页</a>
      <span class="mx-2">/</span>
      <span class="text-foreground">{board.product}</span>
    </nav>

    <header class="mb-8">
      <h1 class="text-foreground mb-2 text-3xl font-semibold tracking-tight">{board.product}</h1>
      <p class="text-muted-foreground text-sm">
        {board.cpu}
        {board.ram ? ` · ${board.ram}` : ""}
        {board.vendor ? ` · ${board.vendor}` : ""}
      </p>
    </header>

    {
      introHtml && (
        <article class="prose prose-slate dark:prose-invert mb-10 max-w-none" set:html={introHtml} />
      )
    }

    <section>
      <h2 class="text-foreground mb-4 text-lg font-semibold">示例列表</h2>
      <ul class="divide-border divide-y rounded-xl border">
        {
          board.examples.map((ex) => (
            <li class="hover:bg-muted/40 transition-colors">
              <a
                href={`/boards/${encodeURIComponent(board.slug)}/${encodeURIComponent(ex.slug)}/`}
                class="text-foreground flex flex-wrap items-center justify-between gap-2 px-4 py-3 no-underline"
              >
                <span class="font-medium">{ex.title}</span>
                <span class="text-muted-foreground flex shrink-0 items-center gap-2 text-sm">
                  <span class="bg-secondary text-secondary-foreground rounded-md px-2 py-0.5 text-xs">
                    {STATUS_LABEL_ZH[ex.status]}
                  </span>
                  {ex.sys ? <span>{ex.sys}</span> : null}
                  {ex.lastUpdate ? <span>{ex.lastUpdate}</span> : null}
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</Layout>
